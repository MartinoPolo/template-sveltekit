{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "template-sveltekit",
	"compatibility_date": "2025-03-27",
	"compatibility_flags": ["nodejs_als"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare",
	},
	"workers_dev": true,
	"preview_urls": true,
}
