{
	"name": "template-sveltekit",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:all": "svelte-kit sync && prettier --write . && oxlint && stylelint \"src/**/*.{css,svelte}\" && pnpm check:fallow && svelte-check --tsconfig ./tsconfig.json && eslint --cache .",
		"check:fallow": "node scripts/fallow-check.js",
		"fallow:audit": "fallow audit --format json --quiet --explain",
		"fallow:save-baseline": "fallow dead-code --save-regression-baseline fallow-baselines/dead-code-regression.json",
		"lint": "oxlint",
		"lint:eslint": "eslint .",
		"lint:css": "stylelint \"src/**/*.{css,svelte}\"",
		"format": "prettier --write .",
		"test": "vitest",
		"test:e2e": "playwright test",
		"prepare": "husky",
		"db:start": "docker compose up -d",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"cf:types": "wrangler types --no-include-runtime",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"storybook": "svelte-kit sync && storybook dev -p 6006",
		"build:storybook": "svelte-kit sync && storybook build"
	},
	"dependencies": {
		"better-auth": "~1.4.22",
		"drizzle-orm": "^0.45.1",
		"mode-watcher": "^1.1.0",
		"postgres": "^3.4.8"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.22",
		"@chromatic-com/storybook": "^5.1.1",
		"@cloudflare/workers-types": "^4.20250530.0",
		"@fallow-cli/win32-x64-msvc": "^2.48.4",
		"@fontsource-variable/figtree": "^5.2.10",
		"@fontsource-variable/noto-sans": "^5.2.10",
		"@inlang/paraglide-js": "^2.15.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.3.3",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.3",
		"@storybook/svelte": "^10.3.3",
		"@storybook/sveltekit": "^10.3.3",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@typescript-eslint/parser": "^8.57.2",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"bits-ui": "^2.17.2",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.1.0",
		"eslint-plugin-check-file": "^3.3.1",
		"eslint-plugin-storybook": "^10.3.3",
		"eslint-plugin-svelte": "^3.16.0",
		"fallow": "^2.48.4",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"oxlint": "^1.58.0",
		"playwright": "^1.58.2",
		"postcss-html": "^1.8.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"shadcn-svelte": "^1.2.7",
		"storybook": "^10.3.3",
		"stylelint": "^17.6.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svelte-eslint-parser": "^1.6.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.1.2",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.78.0"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
