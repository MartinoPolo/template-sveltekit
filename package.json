{
	"name": "template-sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp preview",
		"check:all": "vp check && eslint . && stylelint \"src/**/*.{css,svelte}\" && knip && svelte-check --tsconfig ./tsconfig.json",
		"lint": "vp lint",
		"lint:css": "stylelint \"src/**/*.{css,svelte}\"",
		"format": "vp fmt",
		"test": "vp test",
		"test:e2e": "playwright test",
		"prepare": "vp config"
	},
	"pnpm": {
		"overrides": {
			"vite": "npm:@voidzero-dev/vite-plus-core@latest",
			"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
		}
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@typescript-eslint/parser": "^8.57.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"jsdom": "^29.0.1",
		"knip": "^6.0.6",
		"postcss-html": "^1.8.1",
		"stylelint": "^17.6.0",
		"stylelint-config-html": "^1.1.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"svelte-eslint-parser": "^1.6.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.3.1",
		"vite-plus": "^0.1.14"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"postgres": "^3.4.8"
	}
}
